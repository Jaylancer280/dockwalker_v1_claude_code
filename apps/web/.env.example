# Supabase connection — required for all environments
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Push notifications — optional (no-op when not configured)
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_KEY=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
APNS_KEY_PATH=

# App URL — used for Stripe checkout/portal redirect URLs (falls back to localhost:3000)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public site URL — used by email templates, OAuth redirects, push deep
# links, and share-link generation. Should match your primary production
# domain (https://www.dockwalker.io for production).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional API base override (defaults to relative paths in production).
# Useful for split-domain dev setups; leave blank for normal usage.
NEXT_PUBLIC_API_BASE_URL=

# App version string surfaced in Settings → Account → diagnostics for
# support tickets. Bump on each deploy.
NEXT_PUBLIC_APP_VERSION=0.1.0

# Stripe — optional (subscriptions disabled when not configured)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CREW_PRO=
STRIPE_PRICE_EMPLOYER_PRO=

# AI Advisor (Docky) — optional (tab hidden when not configured)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DOCKY_MODEL=claude-haiku-4-5-20251001
# Set to 'true' after MCA corpus ingestion + quality validation
DOCKY_CORPUS_READY=false

# Rate limiting — optional (no rate limiting when not configured)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Telegram bot notifications — optional (feature hidden when not configured)
# Create a bot via @BotFather on Telegram. The webhook secret is any random
# string; set the same value here and on setWebhook (step 7 of the Telegram
# integration plan).
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=

# Twilio (WhatsApp dispatch + voice TURN) — optional (whatsapp_enabled
# users will fall through to push/email if absent).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# AES-256-GCM key used to encrypt notification_channels.phone_encrypted.
# Required if any user has whatsapp_enabled=true; otherwise WA dispatch
# will fail at decrypt. Generate with: openssl rand -hex 32
NOTIFICATION_ENCRYPTION_KEY=

# ─── Vercel Cron ───
# Bearer token required on every /api/cron/* request. Generate with:
# openssl rand -hex 32. Set same value in Vercel Project Settings →
# Environment Variables (Production scope, marked Sensitive).
CRON_SECRET=

# ─── Transactional Email (Resend) — optional (no-ops when not configured) ───
# RESEND_API_KEY=re_xxx
# RESEND_FROM_EMAIL=DockWalker <noreply@dockwalker.com>

# ─── Error Tracking (Sentry) — optional (no-ops when not configured) ───
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ORG=your-org
# SENTRY_PROJECT=dockwalker
# SENTRY_AUTH_TOKEN=sntrys_xxx  (optional, for source map upload)

# ─── Production SMTP (configured in Supabase Dashboard, not here) ───
# Supabase Dashboard → Project Settings → Auth → SMTP Settings
# Recommended provider: Resend (resend.com) — simple, good deliverability
# Required DNS records: SPF, DKIM (provider-specific), DMARC
# After configuring SMTP, copy email templates from supabase/templates/ into
# Supabase Dashboard → Auth → Email Templates
