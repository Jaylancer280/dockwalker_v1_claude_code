{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true,
        "image": "latest"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "NPM_CONFIG_ENGINE_STRICT": "false"
      },
      "ios": {
        "buildConfiguration": "Release",
        "image": "latest"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "image": "latest"
      },
      "env": {
        "NPM_CONFIG_ENGINE_STRICT": "false"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "gareth@nautalink.io",
        "ascAppId": "6761231147"
      }
    }
  }
}
