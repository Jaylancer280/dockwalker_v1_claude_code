{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./src/*"],
      "@dockwalker/types": ["../../packages/types/src"],
      "@dockwalker/db": ["../../packages/db/src"],
      "@dockwalker/shared": ["../../packages/shared/src"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "nativewind-env.d.ts"
  ]
}
